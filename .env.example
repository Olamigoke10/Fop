# Public site URL (no trailing slash) — canonical links + absolute og:image / twitter:image
# VITE_SITE_URL=https://your-domain.com

# Formspree form endpoint for the newsletter (optional). If unset, submit opens mailto.
# VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxxxxx

# Umami analytics (optional)
# VITE_UMAMI_WEBSITE_ID=
# VITE_UMAMI_SRC=https://cloud.umami.is/script.js
